rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin = the site owner. Console → Authentication → Users for the UID.
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'ckn2vJRf4uTXkZbuvxwY4cX2dO22';
    }

    match /users/{userId} {
      // Read own doc; admin can read anyone's.
      allow read: if request.auth != null
        && (request.auth.uid == userId || isAdmin());

      // Create ONLY your own doc, ONLY as "pending" — blocks self-approval at signup.
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.status == 'pending'
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.keys().hasOnly(['email', 'status', 'createdAt']);

      // Only the admin (site owner) can approve / change status.
      allow update: if isAdmin();

      // No client-side deletes.
      allow delete: if false;
    }

    // Lock everything else down.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
